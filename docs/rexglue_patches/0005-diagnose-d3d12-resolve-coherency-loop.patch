+bool D3D12CommandProcessor::SplitSubmissionForResolveCoherency() {
+  if (!submission_open_ || pipeline_cache_->IsCreatingPipelines()) {
+    return false;
+  }
+  uint64_t split_submission = submission_current_;
+  REXGPU_TRACE("D3D12: splitting submission {} after resolve/coherency batch",
+               split_submission);
+  if (!EndSubmission(false)) {
+    REXGPU_WARN("D3D12: failed to split submission {} after resolve/coherency batch",
+                split_submission);
+    return false;
+  }
+  return BeginSubmission(false);
+}
